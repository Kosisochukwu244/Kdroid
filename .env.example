# Copy to .env and fill in. Never commit the real .env file.

# Cyberwave — get these via `cyberwave twin show <your-twin-uuid>`
CYBERWAVE_API_KEY=
CYBERWAVE_ASSET_ID=
CYBERWAVE_TWIN_ID=
CYBERWAVE_ENVIRONMENT_ID=
CYBERWAVE_WORKFLOW_ID=

# Target crop
CROP_NAME=pepper

# Robot / networking
RASPI_IP=

# Sensor bridge (ESP32 -> MQTT)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_SENSOR_TOPIC=kdroid/esp32/sensors

# Waypoint behaviour
WAYPOINT_TRIGGER_RADIUS_M=0.5
WAYPOINT_COOLDOWN_S=60

# Local-first data (SD card storage on the Pi)
LOCAL_DATA_DIR=~/kdroid_data
LOCAL_DB_PATH=kdroid_local.sqlite3
